# Copy this file to `.env` and adjust for your environment.
# `.env` itself is gitignored.

# Base URL used when returning the shortened link. Change this to your public
# domain when deploying (e.g. "https://sho.rt").
BASE_URL=http://localhost:8000

# SQLAlchemy-style database URL. SQLite is used by default.
DATABASE_URL=sqlite:///./shortener.db

# Length of the generated short codes.
CODE_LENGTH=6
